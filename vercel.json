{
  "rewrites": [
    { "source": "/checkout", "destination": "/" },
    { "source": "/checkout/success", "destination": "/" },
    { "source": "/checkout/failure", "destination": "/" },
    { "source": "/admin", "destination": "/" },
    { "source": "/((?!api/.*|assets/.*|favicon.ico|robots.txt).*)", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
